#!/usr/bin/env -S uv run --script --quiet
# /// script
# requires-python = ">=3.10"
# dependencies = ["telethon>=1.36"]
# ///
"""tg — Telegram CLI that acts as YOUR user account (MTProto via Telethon).

Not a bot: after a one-time `tg login`, every command runs with your own
Telegram identity and sees everything your official apps see.

Config dir (override with TG_CONFIG_DIR): ~/.config/tg/
  config.json   {"api_id": 123456, "api_hash": "..."}   (from https://my.telegram.org)
  tg.session    created by `tg login`
  cursor.json   per-chat/topic read cursors (managed by --advance-cursor / `tg cursor`)

Commands:
  tg login                          one-time interactive login (phone + code [+ 2FA])
  tg logout                         terminate the session and delete the session file
  tg whoami                         show the logged-in account
  tg dialogs [--limit N] [--json]   list chats, newest activity first
  tg read <chat> [--limit N] [--json] [--before-id ID]
          [--since-id ID | --since-cursor] [--advance-cursor]
                                    read recent messages from a chat; --since-* fetches
                                    only messages newer than an id / the stored cursor
                                    (oldest unseen first), --advance-cursor stores the
                                    highest id printed as the new cursor
  tg search <query> [--chat CHAT] [--limit N] [--json]
                                    search messages (global, or within one chat)
  tg send <chat> <text...> [--topic T] [--reply-to ID]
                                    send a message as you (optionally into a forum topic
                                    and/or threaded as a reply to a message id)
  tg topics <chat>                  list forum topics of a group
  tg cursor [<chat>] [--topic T] [--set ID | --clear | --list]
                                    show, set, clear, or list stored read cursors

<chat> may be an @username, a t.me link, a numeric id, or a case-insensitive
substring of a dialog title (unique match required).
<T> (forum topic) may be a numeric topic id or a case-insensitive substring of
a topic title (unique match required); also accepted by `tg read --topic`.
"""

import argparse
import asyncio
import json
import os
import sys
from pathlib import Path

CONFIG_DIR = Path(os.environ.get("TG_CONFIG_DIR", "~/.config/tg")).expanduser()
CONFIG_FILE = CONFIG_DIR / "config.json"
SESSION_FILE = CONFIG_DIR / "tg.session"
CURSOR_FILE = CONFIG_DIR / "cursor.json"


def die(msg, code=1):
    print(f"tg: {msg}", file=sys.stderr)
    sys.exit(code)


def load_config():
    if not CONFIG_FILE.exists():
        die(
            f"missing {CONFIG_FILE}\n"
            "Get api_id + api_hash from https://my.telegram.org (API development tools), then:\n"
            f'  mkdir -p {CONFIG_DIR} && echo \'{{"api_id": 123456, "api_hash": "abc..."}}\' > {CONFIG_FILE}\n'
            "and run `tg login`."
        )
    try:
        cfg = json.loads(CONFIG_FILE.read_text())
        return int(cfg["api_id"]), str(cfg["api_hash"])
    except (json.JSONDecodeError, KeyError, ValueError) as e:
        die(f"invalid {CONFIG_FILE}: {e}")


def make_client():
    from telethon import TelegramClient

    api_id, api_hash = load_config()
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    return TelegramClient(str(SESSION_FILE.with_suffix("")), api_id, api_hash)


async def connected(client):
    await client.connect()
    if not await client.is_user_authorized():
        die("not logged in — run `tg login` first")
    return client


def display_name(entity):
    from telethon.tl.types import User

    if isinstance(entity, User):
        name = " ".join(filter(None, [entity.first_name, entity.last_name]))
        return name or entity.username or str(entity.id)
    return getattr(entity, "title", None) or getattr(entity, "username", None) or str(entity.id)


def entity_kind(entity):
    from telethon.tl.types import Channel, Chat, User

    if isinstance(entity, User):
        return "bot" if entity.bot else "user"
    if isinstance(entity, Chat):
        return "group"
    if isinstance(entity, Channel):
        return "channel" if entity.broadcast else "group"
    return "unknown"


async def resolve_chat(client, ref):
    """Resolve @username / t.me link / numeric id / title substring to an entity."""
    if ref.lstrip("-").isdigit():
        try:
            return await client.get_entity(int(ref))
        except Exception:
            pass
    if ref.startswith("@") or "t.me/" in ref or "+" in ref:
        try:
            return await client.get_entity(ref)
        except Exception as e:
            die(f"could not resolve {ref!r}: {e}")
    # Fall back to matching dialog titles.
    needle = ref.lower()
    exact, partial = [], []
    async for d in client.iter_dialogs():
        name = display_name(d.entity)
        if name.lower() == needle:
            exact.append(d.entity)
        elif needle in name.lower():
            partial.append(d.entity)
    matches = exact or partial
    if len(matches) == 1:
        return matches[0]
    if not matches:
        try:
            return await client.get_entity(ref)
        except Exception:
            die(f"no chat matching {ref!r}")
    names = ", ".join(sorted({display_name(m) for m in matches}))
    die(f"{ref!r} is ambiguous ({len(matches)} chats): {names}")


async def fetch_topics(client, entity):
    from telethon.tl.functions.messages import GetForumTopicsRequest

    try:
        res = await client(
            GetForumTopicsRequest(peer=entity, offset_date=None, offset_id=0, offset_topic=0, limit=100)
        )
    except Exception as e:
        die(f"could not list topics for {display_name(entity)!r} (not a forum group?): {e}")
    return res.topics


async def resolve_topic(client, entity, ref):
    """Resolve a numeric topic id or title substring to a forum topic id."""
    if str(ref).isdigit():
        return int(ref)
    topics = await fetch_topics(client, entity)
    needle = str(ref).lower()
    exact = [t for t in topics if t.title.lower() == needle]
    partial = [t for t in topics if needle in t.title.lower()]
    matches = exact or partial
    if len(matches) == 1:
        return matches[0].id
    if not matches:
        die(f"no topic matching {ref!r} in {display_name(entity)!r}")
    names = ", ".join(t.title for t in matches)
    die(f"topic {ref!r} is ambiguous ({len(matches)}): {names}")


def cursor_key(chat_id, topic_id=None):
    return f"{chat_id}/{topic_id}" if topic_id else str(chat_id)


def load_cursors():
    if not CURSOR_FILE.exists():
        return {}
    try:
        return json.loads(CURSOR_FILE.read_text())
    except json.JSONDecodeError as e:
        die(f"invalid {CURSOR_FILE}: {e}")


def save_cursors(cursors):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    tmp = CURSOR_FILE.with_name(CURSOR_FILE.name + ".tmp")
    tmp.write_text(json.dumps(cursors, ensure_ascii=False, indent=1))
    os.replace(tmp, CURSOR_FILE)


def set_cursor(key, last_id, chat_name, monotonic=True):
    """Store a read cursor. With monotonic=True (implicit advance), re-read the
    file at write time and never move backwards, so concurrent agents that both
    advance can only lose to a HIGHER cursor, never regress each other."""
    from datetime import datetime

    cursors = load_cursors()
    entry = cursors.get(key)
    if monotonic and entry and entry.get("last_id", 0) >= last_id:
        return entry["last_id"]
    cursors[key] = {
        "last_id": last_id,
        "chat": chat_name,
        "updated": datetime.now().astimezone().isoformat(timespec="seconds"),
    }
    save_cursors(cursors)
    return last_id


def msg_text(m):
    if m.message:
        return m.message
    if m.media:
        return f"[{type(m.media).__name__.replace('MessageMedia', '').lower() or 'media'}]"
    if m.action:
        return f"[{type(m.action).__name__.replace('MessageAction', '').lower()}]"
    return "[empty]"


def sender_name(m):
    s = m.sender
    return display_name(s) if s else (m.post_author or "channel")


def msg_dict(m):
    return {
        "id": m.id,
        "date": m.date.astimezone().isoformat(timespec="minutes"),
        "sender": sender_name(m),
        "out": m.out,
        "reply_to": m.reply_to_msg_id,
        "text": msg_text(m),
    }


def print_messages(messages, as_json):
    messages = list(reversed(messages))  # oldest first for readability
    if as_json:
        print(json.dumps([msg_dict(m) for m in messages], ensure_ascii=False, indent=1))
        return
    for m in messages:
        d = m.date.astimezone().strftime("%Y-%m-%d %H:%M")
        text = msg_text(m).replace("\n", "\n    ")
        reply = f" (reply to {m.reply_to_msg_id})" if m.reply_to_msg_id else ""
        print(f"[{m.id}] {d} {sender_name(m)}{reply}: {text}")


PENDING_FILE = CONFIG_DIR / "pending_login.json"


async def _login_done(client):
    me = await client.get_me()
    PENDING_FILE.unlink(missing_ok=True)
    print(f"Logged in as {display_name(me)} (@{me.username or '-'}, id {me.id})")
    print(f"Session stored at {SESSION_FILE}")
    await client.disconnect()


async def cmd_login(args):
    from telethon.errors import SessionPasswordNeededError

    client = make_client()
    await client.connect()
    if await client.is_user_authorized():
        await _login_done(client)
        return

    if args.phone:
        sent = await client.send_code_request(args.phone)
        PENDING_FILE.write_text(json.dumps({"phone": args.phone, "hash": sent.phone_code_hash}))
        PENDING_FILE.chmod(0o600)
        print(f"Code sent to {args.phone}. Finish with: tg login --code <CODE> [--password <2FA>]")
        await client.disconnect()
        return

    if args.code:
        if not PENDING_FILE.exists():
            die("no pending login — start with `tg login --phone +45...`")
        pending = json.loads(PENDING_FILE.read_text())
        try:
            await client.sign_in(pending["phone"], args.code, phone_code_hash=pending["hash"])
        except SessionPasswordNeededError:
            if not args.password:
                die("2FA enabled — rerun with: tg login --code {} --password <your 2FA password>".format(args.code))
            await client.sign_in(password=args.password)
        await _login_done(client)
        return

    if not sys.stdin.isatty():
        die(
            "stdin is not interactive. Use the two-step flow:\n"
            "  tg login --phone +4512345678   (sends the code)\n"
            "  tg login --code 12345 [--password <2FA>]"
        )
    await client.start()  # prompts for phone, code, and 2FA password if set
    await _login_done(client)


async def cmd_logout(args):
    client = await connected(make_client())
    await client.log_out()
    print("Logged out; session file removed.")


async def cmd_whoami(args):
    client = await connected(make_client())
    me = await client.get_me()
    print(f"{display_name(me)} (@{me.username or '-'}, id {me.id}, phone +{me.phone})")
    await client.disconnect()


async def cmd_dialogs(args):
    client = await connected(make_client())
    rows = []
    async for d in client.iter_dialogs(limit=args.limit):
        rows.append(
            {
                "id": d.entity.id,
                "kind": entity_kind(d.entity),
                "name": display_name(d.entity),
                "username": getattr(d.entity, "username", None),
                "unread": d.unread_count,
                "last": d.date.astimezone().isoformat(timespec="minutes") if d.date else None,
            }
        )
    if args.json:
        print(json.dumps(rows, ensure_ascii=False, indent=1))
    else:
        for r in rows:
            uname = f" @{r['username']}" if r["username"] else ""
            unread = f" unread={r['unread']}" if r["unread"] else ""
            print(f"{r['id']:>14}  {r['kind']:<7} {r['name']}{uname}{unread}  ({r['last']})")
    await client.disconnect()


async def cmd_read(args):
    if args.since_id and args.since_cursor:
        die("--since-id and --since-cursor are mutually exclusive")
    client = await connected(make_client())
    entity = await resolve_chat(client, args.chat)
    topic_id = await resolve_topic(client, entity, args.topic) if args.topic else None
    key = cursor_key(entity.id, topic_id)
    kwargs = {"limit": args.limit}
    if args.before_id:
        kwargs["max_id"] = args.before_id
    if topic_id:
        kwargs["reply_to"] = topic_id
    since = args.since_id
    if args.since_cursor:
        entry = load_cursors().get(key)
        since = entry["last_id"] if entry else 0
    if since is not None:
        kwargs["min_id"] = since
        # Oldest-first so --limit takes the OLDEST unseen messages (queue order);
        # advancing the cursor then never skips over unfetched ones.
        kwargs["reverse"] = True
    messages = [m async for m in client.iter_messages(entity, **kwargs)]
    if kwargs.get("reverse"):
        messages = list(reversed(messages))  # print_messages expects newest-first
    print_messages(messages, args.json)
    if args.advance_cursor and messages:
        stored = set_cursor(key, max(m.id for m in messages), display_name(entity))
        print(f"cursor[{key}] = {stored}", file=sys.stderr)
    await client.disconnect()


async def cmd_search(args):
    client = await connected(make_client())
    entity = await resolve_chat(client, args.chat) if args.chat else None
    messages = [m async for m in client.iter_messages(entity, search=args.query, limit=args.limit)]
    if not args.chat:
        # Global results: prefix each line's sender with the chat it came from.
        chats = {}
        for m in messages:
            if m.chat_id not in chats:
                try:
                    chats[m.chat_id] = display_name(await m.get_chat())
                except Exception:
                    chats[m.chat_id] = str(m.chat_id)
        if args.json:
            out = [{**msg_dict(m), "chat": chats[m.chat_id], "chat_id": m.chat_id} for m in reversed(messages)]
            print(json.dumps(out, ensure_ascii=False, indent=1))
        else:
            for m in reversed(messages):
                d = m.date.astimezone().strftime("%Y-%m-%d %H:%M")
                text = msg_text(m).replace("\n", "\n    ")
                print(f"[{m.id}] {d} {chats[m.chat_id]} / {sender_name(m)}: {text}")
    else:
        print_messages(messages, args.json)
    await client.disconnect()


async def cmd_send(args):
    from telethon.tl.types import InputReplyToMessage

    client = await connected(make_client())
    entity = await resolve_chat(client, args.chat)
    kwargs = {}
    suffix = ""
    if args.reply_to and args.topic:
        # Reply to a specific message inside a forum topic: Telegram needs the
        # topic as top_msg_id alongside the replied-to message id.
        topic_id = await resolve_topic(client, entity, args.topic)
        kwargs["reply_to"] = InputReplyToMessage(
            reply_to_msg_id=args.reply_to, top_msg_id=topic_id
        )
        suffix = f" (topic {topic_id}, reply to {args.reply_to})"
    elif args.reply_to:
        # Bare reply: if the target lives in a forum topic, Telegram threads the
        # message into that topic via the reply chain.
        kwargs["reply_to"] = args.reply_to
        suffix = f" (reply to {args.reply_to})"
    elif args.topic:
        kwargs["reply_to"] = await resolve_topic(client, entity, args.topic)
        suffix = f" (topic {kwargs['reply_to']})"
    msg = await client.send_message(entity, " ".join(args.text), **kwargs)
    print(f"Sent to {display_name(entity)}{suffix} (message id {msg.id})")
    await client.disconnect()


async def cmd_topics(args):
    client = await connected(make_client())
    entity = await resolve_chat(client, args.chat)
    topics = await fetch_topics(client, entity)
    if args.json:
        print(
            json.dumps(
                [{"id": t.id, "title": t.title, "unread": t.unread_count} for t in topics],
                ensure_ascii=False,
                indent=1,
            )
        )
    else:
        for t in topics:
            unread = f" unread={t.unread_count}" if t.unread_count else ""
            print(f"{t.id:>6}  {t.title}{unread}")
    await client.disconnect()


async def cmd_cursor(args):
    if args.list:
        cursors = load_cursors()
        if args.json:
            print(json.dumps(cursors, ensure_ascii=False, indent=1))
        else:
            for key, e in sorted(cursors.items()):
                print(f"{key:>20}  last_id={e['last_id']}  {e.get('chat', '?')}  ({e.get('updated', '?')})")
        return
    if not args.chat:
        die("give a <chat> (with optional --topic), or --list")
    client = await connected(make_client())
    entity = await resolve_chat(client, args.chat)
    topic_id = await resolve_topic(client, entity, args.topic) if args.topic else None
    key = cursor_key(entity.id, topic_id)
    if args.clear:
        cursors = load_cursors()
        if cursors.pop(key, None) is not None:
            save_cursors(cursors)
            print(f"cursor[{key}] cleared")
        else:
            print(f"cursor[{key}] was not set")
    elif args.set is not None:
        stored = set_cursor(key, args.set, display_name(entity), monotonic=False)
        print(f"cursor[{key}] = {stored}")
    else:
        entry = load_cursors().get(key)
        if args.json:
            print(json.dumps({key: entry}, ensure_ascii=False, indent=1))
        elif entry:
            print(f"cursor[{key}] = {entry['last_id']}  ({entry.get('updated', '?')})")
        else:
            print(f"cursor[{key}] is not set")
    await client.disconnect()


def main():
    p = argparse.ArgumentParser(
        prog="tg", description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    lg = sub.add_parser("login")
    lg.add_argument("--phone", help="step 1: send a login code to this number (e.g. +4512345678)")
    lg.add_argument("--code", help="step 2: the code Telegram sent you")
    lg.add_argument("--password", help="2FA password, if your account has one")
    lg.set_defaults(fn=cmd_login)
    sub.add_parser("logout").set_defaults(fn=cmd_logout)
    sub.add_parser("whoami").set_defaults(fn=cmd_whoami)

    d = sub.add_parser("dialogs")
    d.add_argument("--limit", type=int, default=30)
    d.add_argument("--json", action="store_true")
    d.set_defaults(fn=cmd_dialogs)

    r = sub.add_parser("read")
    r.add_argument("chat")
    r.add_argument("--limit", type=int, default=20)
    r.add_argument("--before-id", type=int, help="page backwards: only messages older than this id")
    r.add_argument("--since-id", type=int, help="only messages newer than this id, oldest first")
    r.add_argument("--since-cursor", action="store_true", help="only messages newer than the stored cursor")
    r.add_argument("--advance-cursor", action="store_true", help="store the highest id printed as the new cursor")
    r.add_argument("--topic", help="forum topic (numeric id or title substring)")
    r.add_argument("--json", action="store_true")
    r.set_defaults(fn=cmd_read)

    s = sub.add_parser("search")
    s.add_argument("query")
    s.add_argument("--chat", help="restrict search to one chat")
    s.add_argument("--limit", type=int, default=20)
    s.add_argument("--json", action="store_true")
    s.set_defaults(fn=cmd_search)

    snd = sub.add_parser("send")
    snd.add_argument("chat")
    snd.add_argument("text", nargs="+")
    snd.add_argument("--topic", help="forum topic (numeric id or title substring)")
    snd.add_argument(
        "--reply-to",
        type=int,
        metavar="ID",
        help="thread the message as a reply to this message id",
    )
    snd.set_defaults(fn=cmd_send)

    tp = sub.add_parser("topics")
    tp.add_argument("chat")
    tp.add_argument("--json", action="store_true")
    tp.set_defaults(fn=cmd_topics)

    cu = sub.add_parser("cursor")
    cu.add_argument("chat", nargs="?")
    cu.add_argument("--topic", help="forum topic (numeric id or title substring)")
    cu.add_argument("--set", type=int, help="set the cursor to this message id (may move backwards)")
    cu.add_argument("--clear", action="store_true", help="remove the stored cursor")
    cu.add_argument("--list", action="store_true", help="list all stored cursors")
    cu.add_argument("--json", action="store_true")
    cu.set_defaults(fn=cmd_cursor)

    args = p.parse_args()
    asyncio.run(args.fn(args))


if __name__ == "__main__":
    main()
